{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Streamlit app",
      "type": "python",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "Cadastro.py",
        "--server.port=8501"
      ],
      "console": "integratedTerminal",
      "subProcess": True,
      "justMyCode": False
    },
    {
      "name": "Run Python script",
      "type": "python",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": True
    }
  ]
}